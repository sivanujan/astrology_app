    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dom-to-image-more": "^3.7.2",
    "express": "^5.2.1",
    "firebase": "^12.6.0",
    "framer-motion": "^12.23.25",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.12.1",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.556.0",
    "puppeteer": "^24.33.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
