{
  "name": "astrology-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run server:dev\" \"npm run dev --prefix backend\"",
    "server": "tsx server/index.ts",
    "server:dev": "nodemon --watch server --exec tsx server/index.ts",
